! For reference, this template expects the following arguments:
! config: A dictionary of configuration parameters for the simulation.
! lineout: An object containing precomputed mathematical functions and values for initializing fields and particle properties
!
! IMPORTANT: Coordinate rotation for 1D simulation
! The lineout is extracted along the y-axis of the original data.
! In this 1D simulation, the coordinate mapping is:
!   Simulation axis 1 (x1) = Original y
!   Transverse axis 2 (x2) = -Original x  (negated!)
!   Transverse axis 3 (x3) = Original z
! All vector components (B, E, velocities) are rotated accordingly.

!----------global simulation parameters----------
simulation
{
    algorithm = "{{ config['algorithm'] }}",
    parallel_io = "mpi",
}

!--------the node configuration for this simulation--------
node_conf 
{
 node_number = {{ config["node_number"][1] }}, ! number of GPUs you are using
 n_threads = {{ config["n_threads"] }}, ! number of threads per GPU
 tile_number = {{ config["tile_number"][0] }}, ! n_tiles_tot should be greater than n_cells_tot / 1024 and be a power of two. Refer to osiris cuda documentation
 if_periodic(1:1) = .false.,
}


!----------spatial grid----------
grid
{
 nx_p(1:1) = {{ config["nx_p"][0] }}, ! number of cells 
}


!----------time step and global data dump timestep number----------
time_step
{
 dt     = {{ config["dt"] }}, ! time step in wpe^-1
 ndump  = {{ config["ndump"] }}, ! number of time steps between data dumps,
}


!----------restart information----------
restart
{
  ndump_fac = -1,
  ndump_time = 3590, !once/hour
  if_restart = .false.,
  if_remold = .true.,
}

!----------spatial limits ----------
space
{
 xmin(1:1) = {{ lineout.osiris_length[0] | int }},
 xmax(1:1) = {{ lineout.osiris_length[-1] | int }},
}


!----------time limits ----------
time
{
 tmin = 0.0,
 tmax = {{ config["tmax"] }}, ! Just to make your life easier, your upstream gyrotime for an rqm of {{ config["rqm_al"] }} is {{ config["upstream_gyrotime"] }}
}

!----------field solver set up----------
el_mag_fld
{
  type_init_b(1:3) = "math func", "math func", "math func",
  init_b_mfunc(1) = "{{ lineout.math_funcs['magy'] }}",  ! Rotated: y → x1
  init_b_mfunc(2) = "{{ lineout.math_funcs['magx'] }}",  ! Rotated: x → -x2 (negated)
  init_b_mfunc(3) = "{{ lineout.math_funcs['magz'] }}",
  type_init_e(1:3) = "math func", "math func", "math func",
  init_e_mfunc(1) = "{{ lineout.math_funcs['Ey'] }}",  ! Rotated: y → x1
  init_e_mfunc(2) = "{{ lineout.math_funcs['Ex'] }}",  ! Rotated: x → -x2 (negated)
  init_e_mfunc(3) = "{{ lineout.math_funcs['Ez'] }}",
}

!----------boundary conditions for em-fields ----------
emf_bound
{ 
 type(1:2,1) =  "{{ config["emf_boundary_x2"][0] }}", "{{ config["emf_boundary_x2"][1] }}", ! boundaries for x1
 vpml_diffuse(1,1) = {{ config["vpml_diffuse"] }},
 vpml_diffuse(2,1) = {{ config["vpml_diffuse"] }},
 vpml_bnd_size = {{ config["vpml_bnd_size"] }},
}

!----------- electro-magnetic field diagnostics ---------
diag_emf
{
    reports = {{ config["emf_reports"] }},

    ndump_fac_ave = 2,
    ndump_fac_ene_int = 10,
    !ndump_fac_charge_cons = 10,
    n_ave(1:1) = 50,
} 

!----------number of particle species----------
particles
{
  interpolation = "{{ config['interpolation'] }}",
  num_species = 3,
}

!----------information for electrons----------
species
{
 name = "e",
 rqm=-1.0,
 num_par_x(1:1) = {{ config["num_par_x"][0] }}, ! number of particles per cell
}

!----------inital proper velocities - electrons-----------------
udist
{
  use_spatial_uth = .true.,
  use_spatial_ufl = .true.,
  spatial_uth(1) = "{{ lineout.math_funcs['vthele'] }}",
  spatial_uth(2) = "{{ lineout.math_funcs['vthele'] }}",
  spatial_uth(3) = "{{ lineout.math_funcs['vthele'] }}",

  spatial_ufl(1) = "{{ lineout.math_funcs['v_ey'] }}",  ! Rotated: y → x1
  spatial_ufl(2) = "{{ lineout.math_funcs['v_ex'] }}",  ! Rotated: x → -x2 (negated)
  spatial_ufl(3) = "{{ lineout.math_funcs['v_ez'] }}",
}

!----------density profile for electrons----------
profile
{
  profile_type(1:1) = "piecewise-linear",
  num_x = {{ lineout.math_funcs['edens']['x'].count(',') + 1 }},
  x(1:{{ lineout.math_funcs['edens']['x'].count(',') + 1 }},1) = {{ lineout.math_funcs['edens']['x'] }},
  fx(1:{{ lineout.math_funcs['edens']['dens'].count(',') + 1 }},1) = {{ lineout.math_funcs['edens']['dens'] }},
}

!----------boundary conditions for electrons----------
spe_bound
{
 type(1:2,1) = "{{ config["part_boundary_x2"][0] }}","{{ config["part_boundary_x2"][1] }}",
 uth_bnd(1:3,1,1) = {{ lineout._get_field_values('vthele')[0] }},{{ lineout._get_field_values('vthele')[0] }},{{ lineout._get_field_values('vthele')[0] }},
 uth_bnd(1:3,2,1) = {{ lineout._get_field_values('vthele')[1] }},{{ lineout._get_field_values('vthele')[1] }},{{ lineout._get_field_values('vthele')[1] }},
}

!----------diagnostic for electrons----------
diag_species
{
    ndump_fac_ave = 2,
    !ndump_fac_temp = 1,
    ndump_fac_ene = 10,
    ndump_fac_pha = 1,
    n_ave(1:1) = 50,
    rep_udist = "uth1", "uth2", "ufl1", "ufl2",
    ps_gammamin = 1.0,
    ps_gammamax = {{ 3 }},
    ps_ngamma = {{ 128 }},
    reports = {{ config["reports"] }},
    ps_pmin(1:3) = {{ config["e_ps_pmin"][0] }}, {{ config["e_ps_pmin"][1] }}, {{ config["e_ps_pmin"][2] }},
    ps_pmax(1:3) = {{ config["e_ps_pmax"][0] }}, {{ config["e_ps_pmax"][1] }}, {{ config["e_ps_pmax"][2] }},
    ps_xmin(1:1) = {{ lineout.osiris_length[0] | int }}, ! phase space covers the entire domain. change as needed
    ps_xmax(1:1) = {{ lineout.osiris_length[-1] | int }},
    ps_np(1:3) = {{ config["ps_np"][0] }}, {{ config["ps_np"][1] }}, {{ config["ps_np"][2] }},
    ps_nx(1:1) = {{ config["ps_nx"][0] }},
    phasespaces = "p1x1", "p2x1", "p3x1",
}
   
!----------information for Aluminum ions----------
species
{
 name = "al",
 rqm = {{ config["rqm_al"] }},
 num_par_x(1:1) = {{ config["num_par_x"][0] }}, ! number of particles per cell
}

!----------inital proper velocities Aluminum ions-----------------
udist
{
  use_spatial_uth = .true.,
  use_spatial_ufl = .true.,
  spatial_uth(1) = "{{ lineout.math_funcs['vthion'] }}",
  spatial_uth(2) = "{{ lineout.math_funcs['vthion'] }}",
  spatial_uth(3) = "{{ lineout.math_funcs['vthion'] }}",

  spatial_ufl(1) = "{{ lineout.math_funcs['v_iy'] }}",  ! Rotated: y → x1
  spatial_ufl(2) = "{{ lineout.math_funcs['v_ix'] }}",  ! Rotated: x → -x2 (negated)
  spatial_ufl(3) = "{{ lineout.math_funcs['v_iz'] }}",
}

!----------density profile for Aluminum ions----------
profile
{
  profile_type(1:1) = "piecewise-linear",
  num_x = {{ lineout.math_funcs['edens']['x'].count(',') + 1 }},
  x(1:{{ lineout.math_funcs['aldens']['x'].count(',') + 1 }},1) = {{ lineout.math_funcs['aldens']['x'] }},
  fx(1:{{ lineout.math_funcs['aldens']['dens'].count(',') + 1 }},1) = {{ lineout.math_funcs['aldens']['dens'] }},
}

!----------boundary conditions for Alumium ions----------
spe_bound
{
 type(1:2,1) = "thermal", "thermal",
 uth_bnd(1:3,1,1) = {{ lineout._get_field_values('vthion')[0] }},{{ lineout._get_field_values('vthion')[0] }},{{ lineout._get_field_values('vthion')[0] }},
 uth_bnd(1:3,2,1) = {{ lineout._get_field_values('vthion')[1] }},{{ lineout._get_field_values('vthion')[1] }},{{ lineout._get_field_values('vthion')[1] }},
}

!----------diagnostic for Aluminum ions----------
diag_species
{ 
  ndump_fac_ave = 2,
  !ndump_fac_temp = 1,
  ndump_fac_ene = 10,
  ndump_fac_pha = 1,
  n_ave(1:1) = 50,
  rep_udist = "uth1", "uth2", "ufl1", "ufl2",
  ps_gammamin = 1.0,
  ps_gammamax = {{ 3 }},
  ps_ngamma = {{ 128 }},
  reports = {{ config["reports"] }},
  ps_pmin(1:3) = {{ config["i_ps_pmin"][0] }}, {{ config["i_ps_pmin"][1] }}, {{ config["i_ps_pmin"][2] }},
  ps_pmax(1:3) = {{ config["i_ps_pmax"][0] }}, {{ config["i_ps_pmax"][1] }}, {{ config["i_ps_pmax"][2] }},
  ps_xmin(1:1) = {{ lineout.osiris_length[0] | int }}, ! phase space covers the entire domain. change as needed
  ps_xmax(1:1) = {{ lineout.osiris_length[-1] | int }},
  ps_np(1:3) = {{ config["ps_np"][0] }}, {{ config["ps_np"][1] }}, {{ config["ps_np"][2] }},
  ps_nx(1:1) = {{ config["ps_nx"][0] }},
  phasespaces = "p1x1", "p2x1", "p3x1",
}

!----------information for Silicon ions----------
species
{
 name = "si",
 rqm = {{ config["rqm_si"] }},
 num_par_x(1:1) = {{ config["num_par_x"][0] }}, ! number of particles per cell
}

!----------inital proper velocities Silicon ions-----------------
udist
{
  use_spatial_uth = .true.,
  use_spatial_ufl = .true.,
  spatial_uth(1) = "{{ lineout.math_funcs['vthion'] }}",
  spatial_uth(2) = "{{ lineout.math_funcs['vthion'] }}",
  spatial_uth(3) = "{{ lineout.math_funcs['vthion'] }}",

  spatial_ufl(1) = "{{ lineout.math_funcs['v_iy'] }}",  ! Rotated: y → x1
  spatial_ufl(2) = "{{ lineout.math_funcs['v_ix'] }}",  ! Rotated: x → -x2 (negated)
  spatial_ufl(3) = "{{ lineout.math_funcs['v_iz'] }}",
}

!----------density profile for Silicon ions----------
profile
{ 
  profile_type(1:1) = "piecewise-linear",
  num_x = {{ lineout.math_funcs['edens']['x'].count(',') + 1 }},
  x(1:{{ lineout.math_funcs['sidens']['x'].count(',') + 1 }},1) = {{ lineout.math_funcs['sidens']['x'] }},
  fx(1:{{ lineout.math_funcs['sidens']['dens'].count(',') + 1 }},1) = {{ lineout.math_funcs['sidens']['dens'] }},
}

!----------boundary conditions for Silicon ions----------
spe_bound
{
 type(1:2,1) = "thermal","thermal",
 uth_bnd(1:3,1,1) = {{ lineout._get_field_values('vthion')[0] }},{{ lineout._get_field_values('vthion')[0] }},{{ lineout._get_field_values('vthion')[0] }},
 uth_bnd(1:3,2,1) = {{ lineout._get_field_values('vthion')[1] }},{{ lineout._get_field_values('vthion')[1] }},{{ lineout._get_field_values('vthion')[1] }},
}

!----------diagnostic for Silicon ions----------
diag_species
{ 
  ndump_fac_ave = 2,
  !ndump_fac_temp = 1,
  ndump_fac_ene = 10,
  ndump_fac_pha = 1,
  n_ave(1:1) = 50,
  rep_udist = "uth1", "uth2", "ufl1", "ufl2",
  ps_gammamin = 1.0,
  ps_gammamax = {{ 3 }},
  ps_ngamma = {{ 128 }},
  reports = {{ config["reports"] }},
  ps_pmin(1:3) = {{ config["i_ps_pmin"][0] }}, {{ config["i_ps_pmin"][1] }}, {{ config["i_ps_pmin"][2] }},
  ps_pmax(1:3) = {{ config["i_ps_pmax"][0] }}, {{ config["i_ps_pmax"][1] }}, {{ config["i_ps_pmax"][2] }},
  ps_xmin(1:1) = {{ lineout.osiris_length[0] | int }}, ! phase space covers the entire domain. change as needed
  ps_xmax(1:1) = {{ lineout.osiris_length[-1] | int }},
  ps_np(1:3) = {{ config["ps_np"][0] }}, {{ config["ps_np"][1] }}, {{ config["ps_np"][2] }},
  ps_nx(1:1) = {{ config["ps_nx"][0] }},
  phasespaces = "p1x1", "p2x1", "p3x1",
}
!--------Current smoothing----------
smooth
{
  type = "{{ config["smooth_type"] }}",
  order = {{ config["smooth_order"] }},
}
